# ============================================================
# QVC Appointment Booking Bot - Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ============================================================
# TELEGRAM BOT SETUP (Step-by-step)
# ============================================================
#
# Step 1: Create a Telegram Bot
#   1. Open Telegram and search for @BotFather
#   2. Send /newbot
#   3. Choose a name (e.g., "QVC Booking Bot")
#   4. Choose a username (must end in "bot", e.g., "qvc_booking_123_bot")
#   5. BotFather replies with your bot token — copy it below
#
# Step 2: Get Your Chat ID
#   1. Search for @userinfobot in Telegram and start it
#   2. It replies with your chat ID (a number like 123456789)
#   OR:
#   1. Send any message to your new bot
#   2. Visit: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
#   3. Look for "chat":{"id":YOUR_CHAT_ID}
#
# Step 3: Start a Chat
#   1. Open your new bot in Telegram and press "Start"
#   2. This is required before the bot can send you messages
#
# ============================================================

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID (numeric)
TELEGRAM_CHAT_ID=0

# ============================================================
# TELEGRAM API PROXY (recommended for Pakistan/Qatar)
# ============================================================
# Free HTTP proxies die constantly. Deploy a Cloudflare Worker instead:
#   1. Go to workers.cloudflare.com (free account)
#   2. Create a new Worker
#   3. Paste the code from telegram-proxy-worker.js
#   4. Deploy — copy the URL below
#
# If set, this is used FIRST (before any HTTP proxy)
TELEGRAM_API_URL=

# HTTP proxy (fallback — unreliable)
# Leave empty if using TELEGRAM_API_URL or VPN
PROXY_URL=

# ============================================================
# QVC SETTINGS
# ============================================================

# QVC website URL
QVC_URL=https://www.qatarvisacenter.com

# CAPTCHA #2 mode: "telegram" or "manual"
#   telegram = bot screenshots CAPTCHA, sends to Telegram, you reply with solution
#   manual   = bot notifies you, you solve CAPTCHA directly in the browser
CAPTCHA_MODE=telegram

# ============================================================
# OLLAMA CLOUD — AI CAPTCHA SOLVER (optional)
# ============================================================
# If set, the bot tries to auto-solve CAPTCHAs using Ollama Cloud's
# vision model before asking you on Telegram. Free tier available.
#
# Setup:
#   1. Create account at ollama.com
#   2. Go to ollama.com/settings/keys
#   3. Create an API key and paste it below
#
# If not set or if AI fails, falls back to Telegram as usual.
OLLAMA_API_KEY=
# Vision model to use (default: qwen3-vl, good for text-in-image)
OLLAMA_VISION_MODEL=qwen3-vl:235b

# ============================================================
# APPLICANT DETAILS (for auto-fill on session recovery)
# ============================================================
# These are used to auto-fill the login form when the session dies,
# so you don't have to re-enter everything manually.
# Only CAPTCHA needs your input (sent to Telegram).

PASSPORT_NUMBER=
VISA_REF_NUMBER=
MOBILE_NUMBER=
EMAIL_ADDRESS=

# ============================================================
# TIMING (seconds) - adjust if needed
# ============================================================

# How often to check calendar for available slots
POLL_INTERVAL=0.8

# Faster polling during burst mode (after error spikes)
BURST_POLL_INTERVAL=0.3

# How long burst mode lasts
BURST_DURATION=30

# Number of errors in BURST_ERROR_WINDOW to trigger burst mode
BURST_ERROR_THRESHOLD=3

# Time window for counting errors (seconds)
BURST_ERROR_WINDOW=10

# Session keepalive ping interval (no page reload)
KEEPALIVE_INTERVAL=40

# How long to wait for CAPTCHA reply via Telegram
CAPTCHA_TIMEOUT=120

# ============================================================
# PROXY (if Telegram API is blocked on your network)
# ============================================================

# Leave empty if no proxy needed. Required in Pakistan/Qatar where Telegram API is blocked.
# Examples:
#   SOCKS5: socks5://127.0.0.1:1080
#   HTTP:   http://127.0.0.1:8080
#   With auth: socks5://user:pass@host:port
PROXY_URL=

# ============================================================
# BROWSER
# ============================================================

# Delay between browser actions (ms) - increase if site is slow
BROWSER_SLOW_MO=50

# Browser launches maximized automatically (no_viewport=True)

# ============================================================
# PATHS
# ============================================================

# Where to save screenshots (confirmation, CAPTCHA, etc.)
SCREENSHOT_DIR=./screenshots
